{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "right",
  "positionY": "top",
  "layer": "overlay",
  "control-center-layer": "top",
  "layer-shell": true,
  "cssPriority": "application",
  "control-center-margin-top": 10,
  "control-center-margin-right": 10,
  "control-center-width": 400,
  "text-empty": "No notifications",
  "widgets": [
    "menubar#top-bar",
    "buttons-grid#large-controls",
    "backlight",
    "mpris",
    "title",
    "dnd",
    "notifications"
  ],
  "widget-config": {
    "menubar#top-bar": {
      "menu#power": {
        "label": "",
        "position": "right",
        "actions": [
          { "label": "󰜉 Reboot", "command": "systemctl reboot" },
          { "label": " Lock", "command": "hyprlock" },
          { "label": "󰍃 Logout", "command": "hyprctl dispatch exit" },
          { "label": "󰐥 Shut down", "command": "systemctl poweroff" }
        ]
      },
      "buttons#screenshot": {
        "label": "",
        "position": "left",
        "command": "grimblast copy area"
      },
      "buttons#performance": {
        "label": "",
        "position": "left",
        "command": "power-profile-toggle"
      }
    },
    "buttons-grid#large-controls": {
      "buttons-per-row": 2,
      "actions": [
        {
          "label": "󰤨",
          "type": "toggle",
          "active": true,
          "command": "nmcli radio wifi on",
          "update-command": "sh -c '[[ $(nmcli radio wifi) == enabled ]] && echo true || echo false'"
        },
        {
          "label": "",
          "type": "toggle",
          "active": true,
          "command": "bluetoothctl power on",
          "update-command": "sh -c '[[ $(bluetoothctl show | grep Powered) =~ yes ]] && echo true || echo false'"
        }
      ]
    },
    "backlight": { "label": "󰃟" },
    "mpris": {
      "image-size": 96,
      "image-radius": 12
    },
    "title": { "text": "Notifications", "clear-all-button": true },
    "dnd": { "text": "Do Not Disturb" }
  }
}
